# ============================================================
# 生产环境变量模板
# 使用方法：cp .env.example .env && vi .env
# ⚠️  .env 已加入 .gitignore，绝不提交真实密钥到代码仓库
# ============================================================

# ── PostgreSQL 密码 ────────────────────────────────────
DB_PASSWORD=在此填入生产数据库密码

# ── Redis 密码 ────────────────────────────────────────
REDIS_PASSWORD=在此填入生产Redis密码

# ── DeepSeek API 密钥（无默认值，不填启动直接报错）────
DEEPSEEK_API_KEY=sk-在此填入你的真实密钥

# ── Grafana 管理员密码 ─────────────────────────────────
GRAFANA_PASSWORD=在此填入Grafana密码

# ── CORS 允许的前端域名 ──────────────────────────────
CORS_ORIGIN=https://your-domain.com
