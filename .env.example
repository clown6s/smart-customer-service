# ============================================================
# 环境变量模板 — 复制为 .env 并填入真实值
# cp .env.example .env
# ⚠️  .env 已加入 .gitignore，绝不提交真实密钥
# ============================================================

# ── 基础 ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
TZ=Asia/Shanghai

# ── 数据库 ───────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://10.211.55.20:5432/smart_cs
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0

# ── DeepSeek API（必填）─────────────────────────────
DEEPSEEK_API_KEY=sk-xxx-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_TOKENS=1024
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_RETRIES=2

# ── CORS（生产环境请指定具体域名，禁止使用 *）──────
CORS_ORIGIN=http://localhost:5173

# ── 日志 ────────────────────────────────────────────
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_LEVEL_LC4J=WARN

# ── 业务参数 ────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
SESSION_EXPIRE_HOURS=24
SESSION_MAX_HISTORY=10
FAQ_ENABLED=true
EMOTION_ENABLED=true

# ── SSE 线程池 ──────────────────────────────────────
SSE_CORE_POOL_SIZE=4
SSE_MAX_POOL_SIZE=16
SSE_QUEUE_CAPACITY=100

# ── Actuator ────────────────────────────────────────
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
ACTUATOR_HEALTH_DETAILS=when-authorized

# ── Grafana ──────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_admin_password
GRAFANA_ROOT_URL=http://localhost:3000
